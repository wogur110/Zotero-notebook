{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zotero Notebook",
  "version": "1.3.0",
  "identifier": "com.zoteronotebook.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run build:plugin && npm run dev",
    "beforeBuildCommand": "npm run build:plugin && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Zotero Notebook",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/zotero-notebook.xpi"]
  }
}
